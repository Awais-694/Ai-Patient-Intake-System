# =========================================================
# MediAssist AI Patient Intake
# Environment Variables Example
# =========================================================

# ---------------------------------------------------------
# Application
# ---------------------------------------------------------

NEXT_PUBLIC_APP_NAME=MediAssist AI Patient Intake
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------
# MongoDB
# ---------------------------------------------------------

MONGODB_URI=mongodb://127.0.0.1:27017/mediassist

# Optional fallback if any script uses DATABASE_URL
DATABASE_URL=mongodb://127.0.0.1:27017/mediassist

# ---------------------------------------------------------
# Auth.js
# ---------------------------------------------------------

AUTH_SECRET=replace-with-a-long-random-secret
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# ---------------------------------------------------------
# Groq AI
# ---------------------------------------------------------

GROQ_API_KEY=replace-with-your-groq-api-key

# Optional model configuration
GROQ_MODEL=llama-3.3-70b-versatile

# ---------------------------------------------------------
# Seed scripts
# ---------------------------------------------------------

SEED_DEFAULT_PASSWORD=Password123
SEED_DOCTOR_PASSWORD=Doctor123

SEED_ADMIN_EMAIL=admin@mediassist.com
SEED_ADMIN_PASSWORD=Admin12345

# ---------------------------------------------------------
# Optional development settings
# ---------------------------------------------------------

NODE_ENV=development